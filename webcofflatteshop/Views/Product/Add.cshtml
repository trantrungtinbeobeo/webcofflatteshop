@model webcofflatteshop.Models.Product
@using System.Globalization
@{
    ViewData["Title"] = "Admin - Thêm sản phẩm";
    var recentProducts = (ViewBag.RecentProducts as IEnumerable<webcofflatteshop.Models.Product>)?.Take(4).ToList() ?? new List<webcofflatteshop.Models.Product>();
    string FormatPrice(decimal price) => string.Format(CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} ₫", price);
}

<aside class="fixed left-0 top-0 z-40 hidden h-screen w-[280px] flex-col border-r border-outline-variant bg-surface-container-lowest p-gutter md:flex">
    <a asp-controller="Product" asp-action="Index" class="mb-section-gap flex items-center gap-3 text-primary text-decoration-none">
        <span class="material-symbols-outlined rounded-full bg-primary-fixed p-3 text-primary">local_cafe</span>
        <div>
            <h1 class="font-headline-md text-primary">Komorebi</h1>
            <p class="font-label-md text-secondary">Admin Dashboard</p>
        </div>
    </a>
    <nav class="flex-grow space-y-3">
        <a asp-action="Add" class="flex items-center gap-3 rounded-xl bg-primary px-4 py-3 font-label-md text-on-primary text-decoration-none"><span class="material-symbols-outlined">inventory_2</span>Sản phẩm</a>
        <a asp-action="UploadImageList" class="flex items-center gap-3 rounded-xl px-4 py-3 font-label-md text-secondary text-decoration-none transition-soft hover:bg-surface-container"><span class="material-symbols-outlined">image</span>Media</a>
        <a asp-action="Index" class="flex items-center gap-3 rounded-xl px-4 py-3 font-label-md text-secondary text-decoration-none transition-soft hover:bg-surface-container"><span class="material-symbols-outlined">storefront</span>Xem shop</a>
    </nav>
    <div class="rounded-xl bg-surface-container p-4">
        <p class="font-label-md text-primary">Admin</p>
        <p class="text-caption text-secondary">Quản lý menu và danh mục</p>
    </div>
</aside>

<div class="min-h-screen p-margin-mobile md:ml-[280px] md:p-margin-desktop">
    <header class="mx-auto mb-gutter flex max-w-container-max items-end justify-between">
        <div>
            <nav class="mb-2 flex items-center gap-2 text-caption text-secondary">
                <span>Admin</span>
                <span class="material-symbols-outlined text-[12px]">chevron_right</span>
                <span class="font-semibold text-primary">Sản phẩm</span>
            </nav>
            <h2 class="font-headline-md text-primary">Thêm sản phẩm mới</h2>
        </div>
        <div class="hidden md:block">
            <span class="text-caption font-medium uppercase tracking-widest text-secondary">Thứ Sáu, 29 tháng 5, 2026</span>
        </div>
    </header>

    @if (TempData["CategorySuccess"] is string cOk)
    {
        <div class="mx-auto mb-gutter max-w-container-max rounded-xl border border-primary-fixed bg-primary-fixed/50 p-4 text-primary">@cOk</div>
    }
    @if (TempData["CategoryError"] is string cErr)
    {
        <div class="mx-auto mb-gutter max-w-container-max rounded-xl border border-error bg-error-container p-4 text-on-error-container">@cErr</div>
    }

    <div class="mx-auto grid max-w-container-max grid-cols-1 gap-gutter lg:grid-cols-12">
        <section class="space-y-gutter lg:col-span-8">
            <div class="rounded-xl border border-outline-variant/20 bg-surface-container-lowest p-gutter custom-shadow">
                <h3 class="mb-6 flex items-center gap-2 font-label-md text-primary">
                    <span class="material-symbols-outlined text-[20px]">info</span>
                    Thông tin cơ bản
                </h3>
                <form asp-action="Add" method="post" id="product-form" class="space-y-6">
                    <div asp-validation-summary="All" class="validation-summary-errors rounded-lg bg-error-container/60 p-3"></div>
                    <div>
                        <label asp-for="Name" class="mb-2 block font-label-md text-secondary">Tên sản phẩm</label>
                        <input asp-for="Name" class="w-full rounded-lg border border-outline-variant bg-white px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Ví dụ: Cà phê Muối Sài Gòn" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>
                    <div class="grid grid-cols-1 gap-gutter md:grid-cols-2">
                        <div>
                            <label asp-for="Price" class="mb-2 block font-label-md text-secondary">Giá bán (VND)</label>
                            <div class="relative">
                                <input asp-for="Price" class="w-full rounded-lg border border-outline-variant bg-white px-4 py-3 pr-12 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary" placeholder="45000" />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-caption text-secondary">₫</span>
                            </div>
                            <span asp-validation-for="Price" class="field-validation-error"></span>
                        </div>
                        <div>
                            <label asp-for="CategoryId" class="mb-2 block font-label-md text-secondary">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="w-full appearance-none rounded-lg border border-outline-variant bg-white px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary"></select>
                            <span asp-validation-for="CategoryId" class="field-validation-error"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="Description" class="mb-2 block font-label-md text-secondary">Mô tả sản phẩm</label>
                        <textarea asp-for="Description" rows="4" class="w-full resize-none rounded-lg border border-outline-variant bg-white px-4 py-3 text-body-md outline-none transition-all focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Nhập câu chuyện về hương vị hoặc thành phần..."></textarea>
                        <span asp-validation-for="Description" class="field-validation-error"></span>
                    </div>
                    <div class="grid grid-cols-1 gap-gutter md:grid-cols-2">
                        <div class="flex items-center justify-between rounded-xl border border-outline-variant/30 bg-surface-container-low p-6">
                            <div><p class="font-label-md text-primary">Trạng thái sản phẩm</p><p class="text-caption text-secondary">Hiển thị trên menu khách hàng</p></div>
                            <span class="material-symbols-outlined text-primary">toggle_on</span>
                        </div>
                        <div class="flex items-center justify-between rounded-xl border border-outline-variant/30 bg-surface-container-low p-6">
                            <div><p class="font-label-md text-primary">Món nổi bật</p><p class="text-caption text-secondary">Gắn tag Komorebi Choice</p></div>
                            <span class="material-symbols-outlined text-secondary">kid_star</span>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        <section class="space-y-gutter lg:col-span-4">
            <div class="rounded-xl border border-dashed border-outline-variant bg-surface-container-lowest p-gutter text-center custom-shadow">
                <span class="material-symbols-outlined mx-auto mb-4 rounded-full bg-primary-fixed p-4 text-[34px] text-primary">add_photo_alternate</span>
                <h3 class="font-label-md text-primary">Ảnh sản phẩm</h3>
                <p class="mt-2 text-caption text-secondary">Sau khi tạo sản phẩm, vào Media để upload ảnh cho món này.</p>
                <a asp-action="UploadImageList" class="mt-5 inline-flex rounded-full border border-outline px-5 py-3 font-label-md text-primary text-decoration-none">Mở Media</a>
            </div>

            <div class="rounded-xl bg-surface-container-lowest p-gutter custom-shadow">
                <h3 class="mb-3 font-label-md text-primary">Thêm danh mục nhanh</h3>
                <p class="mb-4 text-caption text-secondary">Tạo danh mục mới để quản lý menu linh hoạt hơn.</p>
                <form asp-action="AddCategory" method="post" class="space-y-3">
                    <input name="categoryName" class="w-full rounded-lg border border-outline-variant bg-white px-4 py-3 text-body-md focus:border-primary focus:ring-primary" placeholder="Ví dụ: Seasonal Drinks" />
                    <button type="submit" class="w-full rounded-full bg-secondary-container py-3 font-label-md text-on-secondary-container">Thêm danh mục</button>
                </form>
            </div>

            <div class="rounded-xl bg-primary p-gutter text-on-primary custom-shadow">
                <h3 class="mb-4 font-headline-md">Hoàn tất</h3>
                <div class="space-y-3">
                    <button type="submit" form="product-form" class="w-full rounded-full bg-primary-fixed py-4 font-label-md text-primary">Lưu sản phẩm</button>
                    <a asp-action="Index" class="block w-full rounded-full border border-on-primary/30 py-4 text-center font-label-md text-on-primary text-decoration-none">Hủy và về menu</a>
                </div>
            </div>
        </section>
    </div>

    <section class="mx-auto mt-section-gap max-w-container-max">
        <h3 class="mb-6 font-headline-md text-primary">Sản phẩm vừa cập nhật</h3>
        <div class="overflow-hidden rounded-xl bg-surface-container-lowest custom-shadow">
            <table class="w-full text-left">
                <thead class="border-b border-outline-variant bg-surface-container-low">
                    <tr>
                        <th class="px-gutter py-4 font-label-md text-secondary">Sản phẩm</th>
                        <th class="hidden px-gutter py-4 font-label-md text-secondary md:table-cell">Danh mục</th>
                        <th class="px-gutter py-4 font-label-md text-secondary">Giá</th>
                        <th class="px-gutter py-4 font-label-md text-secondary">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/50">
                    @foreach (var product in recentProducts)
                    {
                        <tr>
                            <td class="px-gutter py-4 font-label-md text-primary">@product.Name</td>
                            <td class="hidden px-gutter py-4 text-body-md text-secondary md:table-cell">@(product.Category?.Name ?? "Chưa phân loại")</td>
                            <td class="px-gutter py-4 text-body-md text-primary">@FormatPrice(product.Price)</td>
                            <td class="px-gutter py-4"><span class="rounded-full bg-primary-fixed px-3 py-1 text-caption text-primary">Đang bán</span></td>
                        </tr>
                    }
                    @if (!recentProducts.Any())
                    {
                        <tr><td colspan="4" class="px-gutter py-8 text-center text-secondary">Chưa có sản phẩm nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
