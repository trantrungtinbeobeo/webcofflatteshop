@model webcofflatteshop.Models.Product
@{ ViewData["Title"] = "Upload ảnh sản phẩm"; }
@if (TempData["SuccessMessage"] is string ok) { <div class="alert alert-success">@ok</div> }

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <div class="card coffee-card p-4 p-md-5 shadow-sm upload-form-card">
            <h2 class="mb-3">Ảnh sản phẩm: <span class="text-accent">@Model.Name</span></h2>
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/default-coffee.svg" : Model.ImageUrl)" class="detail-image mb-3" alt="@Model.Name" />
            <form asp-action="UploadImage" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="mt-2">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3"><label class="form-label">Chọn ảnh mới (JPG, PNG, WEBP)</label><input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" required /></div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-success">Upload / Sửa ảnh</button>
                    <button type="submit" formaction="@Url.Action("RemoveProductImage", "Product", new { id = Model.Id })" class="btn btn-outline-danger">Xóa ảnh</button>
                    <a asp-action="UploadImageList" class="btn btn-outline-secondary">Danh sách sản phẩm</a>
                </div>
            </form>
        </div>
    </div>
</div>
