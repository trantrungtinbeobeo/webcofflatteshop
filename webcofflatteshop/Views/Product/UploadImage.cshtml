@model webcofflatteshop.Models.Product
@{
    ViewData["Title"] = "Upload ảnh sản phẩm";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <div class="card coffee-card p-4 p-md-5 shadow-sm upload-form-card">
            <h2 class="mb-3">Upload ảnh cho: <span class="text-accent">@Model.Name</span></h2>
            <p class="text-muted">Ảnh nên có tỉ lệ ngang để hiển thị đẹp trong danh sách sản phẩm.</p>

            <form asp-action="UploadImage" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="mt-3">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">Chọn ảnh (JPG, PNG, WEBP)</label>
                    <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" required />
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-success">Upload ngay</button>
                    <a asp-action="UploadImageList" class="btn btn-outline-secondary">Danh sách sản phẩm</a>
                    <a asp-action="Display" asp-route-id="@Model.Id" class="btn btn-outline-dark">Xem chi tiết</a>
                </div>
            </form>
        </div>
    </div>
</div>
