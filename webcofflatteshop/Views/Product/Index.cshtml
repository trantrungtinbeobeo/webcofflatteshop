@model IEnumerable<webcofflatteshop.Models.Product>
@{
    ViewData["Title"] = "Coffee Menu";
    var banners = ViewBag.Banners as IEnumerable<string> ?? new[] { "/images/default-coffee.svg" };
    string IconOf(string n) => n.ToLower().Contains("matcha") ? "🍃" : n.ToLower().Contains("chocolate") ? "🍫" : n.ToLower().Contains("croissant") || n.ToLower().Contains("cake") || n.ToLower().Contains("tiramisu") ? "🥐" : "☕";
}

<div id="marketingBanner" class="carousel slide mb-4 rounded-banner overflow-hidden" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-inner banner-inner">
        @{ var i = 0; }
        @foreach (var banner in banners)
        {
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <img src="@banner" class="d-block w-100 banner-image" alt="Banner @(i+1)" />
                <div class="carousel-caption text-start">
                    <h3>Cozy Coffee Shop</h3>
                    <p>Hương vị dịu dàng cho một ngày thật chill ☕</p>
                </div>
            </div>
            i++;
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#marketingBanner" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
    <button class="carousel-control-next" type="button" data-bs-target="#marketingBanner" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="m-0 friendly-title">Coffee Shop Menu ☕</h2>
    <button id="openCartBtn" type="button" class="btn btn-soft rounded-pill">🛒 Giỏ hàng <span id="cartCount" class="badge bg-light text-dark ms-1">0</span></button>
</div>

<div class="row g-4">
@foreach (var product in Model)
{
    var imageUrl = string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/default-coffee.svg" : product.ImageUrl;
    <div class="col-12 col-sm-6 col-lg-4">
        <div class="card coffee-card h-100 shadow-sm product-hover">
            <span class="product-type-icon">@IconOf(product.Name)</span>
            <img src="@imageUrl" class="card-img-top product-image js-open-detail" alt="@product.Name" data-name="@product.Name" data-description="@product.Description" data-price="@product.Price.ToString("0.00")" data-display-price="@product.Price.ToString("C")" data-image="@imageUrl" />
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">@product.Name</h5>
                <p class="card-text text-muted flex-grow-1">@product.Description</p>
                <p class="product-price">@product.Price.ToString("C")</p>
                <button type="button" class="btn btn-soft btn-order w-100 js-open-detail" data-name="@product.Name" data-description="@product.Description" data-price="@product.Price.ToString("0.00")" data-display-price="@product.Price.ToString("C")" data-image="@imageUrl">Đặt hàng ngay</button>
            </div>
        </div>
    </div>
}
</div>

<div id="productOverlay" class="custom-overlay" hidden>
    <div class="custom-modal coffee-card">
        <button id="closeDetailBtn" class="btn btn-sm btn-outline-secondary rounded-pill">Đóng</button>
        <div class="row g-4 align-items-center mt-1">
            <div class="col-md-5"><img id="modalProductImage" src="/images/default-coffee.svg" class="detail-image" alt="Product" /></div>
            <div class="col-md-7">
                <h3 id="modalProductName"></h3>
                <p id="modalProductDesc" class="text-muted"></p>
                <ul class="small text-muted mb-2"><li>Pha chế từ nguyên liệu tươi mới mỗi ngày.</li><li>Phù hợp dùng tại quán hoặc mang đi.</li><li>Có thể tuỳ chỉnh ít đường/ít đá khi đặt.</li></ul>
                <p id="modalProductPrice" class="product-price"></p>
                <div class="d-flex align-items-end gap-2 mb-2">
                    <div><label class="form-label">Số lượng</label><input id="modalQty" type="number" class="form-control" min="1" value="1" /></div>
                    <button id="addToCartBtn" type="button" class="btn btn-soft px-4">Đặt hàng</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="cartPanel" class="cart-panel">
    <div class="cart-panel-header d-flex justify-content-between align-items-center">
        <h5 class="m-0">Giỏ hàng của bạn</h5><button id="closeCartBtn" class="btn btn-sm btn-outline-secondary rounded-pill">Đóng</button>
    </div>
    <div id="cartItems" class="mt-3"></div>
</div>

@section Scripts {
<script>
(() => {
  const overlay = document.getElementById('productOverlay');
  const nameEl = document.getElementById('modalProductName');
  const descEl = document.getElementById('modalProductDesc');
  const priceEl = document.getElementById('modalProductPrice');
  const imageEl = document.getElementById('modalProductImage');
  const qtyEl = document.getElementById('modalQty');
  const addBtn = document.getElementById('addToCartBtn');
  const cartCount = document.getElementById('cartCount');
  const cartPanel = document.getElementById('cartPanel');
  const cartItems = document.getElementById('cartItems');
  let current = null;

  const getCart = () => JSON.parse(localStorage.getItem('coffee_cart') || '[]');
  const setCart = (v) => localStorage.setItem('coffee_cart', JSON.stringify(v));

  const renderCart = () => {
    const cart = getCart();
    cartCount.textContent = cart.reduce((s, i) => s + i.qty, 0);
    cartItems.innerHTML = cart.length ? cart.map(i => `<div class='border rounded p-2 mb-2 d-flex justify-content-between'><div><strong>${i.name}</strong><div class='small text-muted'>SL: ${i.qty}</div></div><div>$${(i.price*i.qty).toFixed(2)}</div></div>`).join('') : "<p class='text-muted mb-0'>Chưa có sản phẩm nào.</p>";
  };

  document.querySelectorAll('.js-open-detail').forEach(el => el.addEventListener('click', () => {
    current = { name: el.dataset.name, price: parseFloat(el.dataset.price) };
    nameEl.textContent = el.dataset.name;
    descEl.textContent = el.dataset.description;
    priceEl.textContent = el.dataset.displayPrice;
    imageEl.src = el.dataset.image;
    qtyEl.value = 1;
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
  }));

  document.getElementById('closeDetailBtn').addEventListener('click', () => { overlay.hidden = true; document.body.style.overflow = ''; });
  overlay.addEventListener('click', (e) => { if (e.target === overlay) { overlay.hidden = true; document.body.style.overflow = ''; }});

  addBtn.addEventListener('click', () => {
    if (!current) return;
    const qty = Math.max(1, parseInt(qtyEl.value || '1'));
    const cart = getCart();
    const idx = cart.findIndex(x => x.name === current.name);
    if (idx >= 0) cart[idx].qty += qty; else cart.push({ ...current, qty });
    setCart(cart);
    renderCart();
    overlay.hidden = true;
    document.body.style.overflow = '';
  });

  document.getElementById('openCartBtn').addEventListener('click', () => cartPanel.classList.add('show'));
  document.getElementById('closeCartBtn').addEventListener('click', () => cartPanel.classList.remove('show'));
  renderCart();
})();
</script>
}
