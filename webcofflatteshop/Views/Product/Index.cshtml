@model IEnumerable<webcofflatteshop.Models.Product>
@using System.Globalization
@{
    ViewData["Title"] = "Menu";
    ViewData["UseStitcheditLayout"] = true;
    var products = Model?.ToList() ?? new List<webcofflatteshop.Models.Product>();
    var banners = (ViewBag.Banners as IEnumerable<string>)?.Where(b => !string.IsNullOrWhiteSpace(b)).ToList() ?? new List<string>();
    if (!banners.Any()) banners.Add("/images/default-coffee.svg");
    var categories = products.Select(p => p.Category?.Name).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().ToList();
    string FormatPrice(decimal price) => string.Format(CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} VNĐ", price);
    string DataPrice(decimal price) => price.ToString(CultureInfo.InvariantCulture);
    string ImageOf(webcofflatteshop.Models.Product p) => string.IsNullOrWhiteSpace(p.ImageUrl) ? "/images/default-coffee.svg" : p.ImageUrl;
}

    <!-- TopNavBar -->
    <nav class="sticky top-0 z-50 bg-surface shadow-[0_10px_30px_rgba(62,39,35,0.05)]">
        <div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-unit max-w-container-max mx-auto">
            <div class="flex items-center gap-unit">
                <div class="flex items-center gap-3">
                    <img src="/images/logo.svg" alt="Cherry Blossom Logo" class="h-10 w-auto">
                    <h1 class="font-['Noto_Serif'] text-[32px] font-bold leading-none">
                        <span style="color: #3e2723;" class="">Coffe</span><span style="color: #81c784;" class="">-latte</span><span style="color: #f48fb1;" class="">Kawaii</span>
                    </h1>
                </div>
            </div>
            <div class="hidden md:flex gap-gutter items-center">
                <a class="font-body-md text-primary border-b-2 border-primary pb-1 text-decoration-none" asp-controller="Product" asp-action="Index">Menu</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" href="#story">Our Story</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" asp-controller="Product" asp-action="Add">Admin</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" asp-controller="Product" asp-action="UploadImageList">Media</a>
            </div>
            <div class="flex items-center gap-unit">
                <button class="relative p-2 text-primary hover:bg-secondary-container rounded-full transition-colors" onclick="toggleCart()">
                    <span class="material-symbols-outlined" data-icon="shopping_cart">shopping_cart</span>
                    <span id="cartCount" class="absolute top-0 right-0 bg-primary text-white text-[10px] w-4 h-4 flex items-center justify-center rounded-full">0</span>
                </button>
                <button class="md:hidden p-2 text-primary">
                    <span class="material-symbols-outlined" data-icon="menu">menu</span>
                </button>
            </div>
        </div>
    </nav>
    <!-- SideNavBar (Cart Drawer) -->
    <div class="fixed right-0 top-0 h-full w-full md:w-[400px] bg-surface-container-lowest shadow-2xl z-[60] translate-x-full transition-transform duration-300 flex flex-col" id="cartDrawer">
        <div class="p-gutter flex justify-between items-center border-b border-outline-variant">
            <div>
                <h2 class="font-headline-md text-headline-md text-primary">Your Selection</h2>
                <p class="font-caption text-caption text-secondary">Carefully crafted for you</p>
            </div>
            <button class="p-2 hover:bg-surface-container rounded-full" onclick="toggleCart()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div id="cartItems" class="flex-grow overflow-y-auto p-gutter space-y-gutter">
            <!-- Cart Item 1 -->
            <div class="flex gap-4">
                <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0">
                    <img class="w-full h-full object-cover" data-alt="A close up view of a rich Vietnamese iced coffee with condensed milk, known as Phin Sua Da, showing beautiful marbling effects as the coffee mixes with the white milk. The scene is set in a sun-drenched, minimalist cafe with warm wooden textures and soft morning light casting gentle shadows. The aesthetic is organic, premium, and deeply inviting, highlighting the artisanal quality of the brew." src="https://lh3.googleusercontent.com/aida-public/AB6AXuB8jEPEKraHk9XkustXEZj7D1Djk0kPw6QXSjVsNZnCc8JM4qb_uBeK6LB3tL38pBNoJ2uxukpglSINNSk936ksIWNWTITpo5xl01IMyCDeqAgNUkyuy2KxQjrrnG6knkP5tp7Q1BagpTOUvMwTyPFrje1ZtrGU7TMQUpOyt1FP-fW3Y8Q9XSJIDCO7BXQkMVwKwFIKfp1dm673erFZxVkImXtsOs3eKLQl9tE9ehvGrLWzfVDpsDzGMmClP9NaTEedfiPmqNU1jy8">
                </div>
                <div class="flex-grow">
                    <p class="font-label-md text-label-md text-primary">Phin Sữa Đá</p>
                    <p class="font-caption text-caption text-secondary">Truyền thống</p>
                    <div class="flex justify-between items-center mt-2">
                        <span class="font-body-md text-primary">45.000 VNĐ</span>
                        <div class="flex items-center gap-2">
                            <button class="w-6 h-6 border border-outline rounded flex items-center justify-center">-</button>
                            <span class="">1</span>
                            <button class="w-6 h-6 border border-outline rounded flex items-center justify-center">+</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Cart Item 2 -->
            <div class="flex gap-4">
                <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0">
                    <img class="w-full h-full object-cover" data-alt="A vibrant, frothy Matcha Latte in a ceramic artisanal cup, showcasing a deep green color and velvety microfoam. The cup sits on a clean, light-colored stone surface with a few stray green tea powder particles around it, suggesting a fresh preparation. The lighting is bright and airy, embodying a serene Kyoto tea house atmosphere with a modern, high-end minimalist design focus." src="https://lh3.googleusercontent.com/aida-public/AB6AXuB9dkxo17JT35NDrgw0b1_51Ktzj3280b3asY6qAccloiaZcUyaOhJOhAkk2NkctYZFp-Z0txCAO12UDDQtOxtHinQx3MMfT03HnV69vtstw1A0kG1S9WwA37_yqXPmgKlH03YnIL9otImOipNO__r28DquW-Z1fad_isqHBy_t3y8c0d0VArzU7f6-QzjuRn7htcK8KH7K8OpOHBBlr6hcETXVjfiCeUfTt6y0gjcobvGYvuLpnq6X5jtmLRphg9xRhV_aieuyCj4">
                </div>
                <div class="flex-grow">
                    <p class="font-label-md text-label-md text-primary">Matcha Latte</p>
                    <p class="font-caption text-caption text-secondary">Trà xanh Kyoto</p>
                    <div class="flex justify-between items-center mt-2">
                        <span class="font-body-md text-primary">65.000 VNĐ</span>
                        <div class="flex items-center gap-2">
                            <button class="w-6 h-6 border border-outline rounded flex items-center justify-center">-</button>
                            <span class="">1</span>
                            <button class="w-6 h-6 border border-outline rounded flex items-center justify-center">+</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="p-gutter bg-surface-container border-t border-outline-variant space-y-4">
            <div class="flex justify-between font-label-md text-label-md text-primary">
                <span class="">Subtotal</span>
                <span id="cartTotal" class="">110.000 VNĐ</span>
            </div>
            <button class="w-full py-4 bg-primary text-on-primary font-label-md rounded-lg hover:brightness-110 transition-soft flex justify-between px-6 items-center">
                <span class="">Proceed to Checkout</span>
                <span class="material-symbols-outlined">arrow_forward</span>
            </button>
        </div>
    </div>
    <!-- Main Content -->
    <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-gutter">
        <!-- Hero Carousel -->
        <section class="relative rounded-xl overflow-hidden h-[400px] mb-section-gap group">
            <div class="h-full relative overflow-hidden" id="hero-slider">
                @foreach (var banner in banners.Select((url, index) => new { url, index }))
                {
                    <div class="slide absolute inset-0 transition-opacity duration-1000 @(banner.index == 0 ? "opacity-100" : "opacity-0")">
                        <img class="w-full h-full object-cover" alt="Coffee shop hero @(banner.index + 1)" src="@banner.url">
                        <div class="absolute inset-0 hero-gradient flex items-end p-gutter">
                            <div class="text-white max-w-xl">
                                <h1 class="font-display-lg text-display-lg mb-4">Hương Vị Nghệ Thuật</h1>
                                <p class="font-body-lg text-body-lg opacity-90">Sự kết hợp hoàn hảo giữa tâm hồn Sài Gòn và hơi thở cố đô Kyoto.</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
        <!-- Category Pills -->
        <section class="flex gap-4 overflow-x-auto hide-scrollbar mb-gutter py-2">
            <button class="px-6 py-2 bg-primary text-on-primary rounded-full font-label-md whitespace-nowrap transition-soft">Tất cả</button>
            @foreach (var category in categories)
            {
                <button class="px-6 py-2 bg-surface text-primary border border-outline rounded-full font-label-md whitespace-nowrap hover:bg-secondary-container transition-soft">@category</button>
            }
            @if (!categories.Any())
            {
                <button class="px-6 py-2 bg-surface text-primary border border-outline rounded-full font-label-md whitespace-nowrap hover:bg-secondary-container transition-soft">Coffee (Cà Phê)</button>
                <button class="px-6 py-2 bg-surface text-primary border border-outline rounded-full font-label-md whitespace-nowrap hover:bg-secondary-container transition-soft">Matcha (Trà Xanh)</button>
                <button class="px-6 py-2 bg-surface text-primary border border-outline rounded-full font-label-md whitespace-nowrap hover:bg-secondary-container transition-soft">Chocolate (Sô-cô-la)</button>
                <button class="px-6 py-2 bg-surface text-primary border border-outline rounded-full font-label-md whitespace-nowrap hover:bg-secondary-container transition-soft">Bakery (Bánh Ngọt)</button>
            }
        </section>
        <!-- Product Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
            @foreach (var product in products)
            {
                var imageUrl = ImageOf(product);
                <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_10px_30px_rgba(62,39,35,0.05)] transition-soft hover:-translate-y-1 hover:shadow-xl group">
                    <div class="relative aspect-square overflow-hidden cursor-pointer js-open-detail" data-name="@product.Name" data-description="@product.Description" data-price="@DataPrice(product.Price)" data-display-price="@FormatPrice(product.Price)" data-image="@imageUrl">
                        <img class="w-full h-full object-cover transition-soft group-hover:scale-105" alt="@product.Name" src="@imageUrl">
                        <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-md p-2 rounded-full">
                            <span class="material-symbols-outlined text-primary">coffee</span>
                        </div>
                    </div>
                    <div class="p-gutter">
                        <h3 class="font-headline-md text-headline-md text-primary mb-1">@product.Name</h3>
                        <p class="font-body-md text-secondary mb-4 line-clamp-2">@product.Description</p>
                        <div class="flex justify-between items-center gap-3">
                            <span class="font-label-md text-on-tertiary-container text-lg whitespace-nowrap">@FormatPrice(product.Price)</span>
                            <button type="button" class="js-open-detail px-4 py-2 bg-primary text-on-primary rounded-lg font-label-md hover:brightness-125 transition-soft" data-name="@product.Name" data-description="@product.Description" data-price="@DataPrice(product.Price)" data-display-price="@FormatPrice(product.Price)" data-image="@imageUrl">Thêm vào giỏ</button>
                        </div>
                    </div>
                </div>
            }
            @if (!products.Any())
            {
                <div class="md:col-span-2 lg:col-span-3 bg-surface-container-lowest rounded-xl p-gutter text-center shadow-[0_10px_30px_rgba(62,39,35,0.05)]">
                    <h3 class="font-headline-md text-primary">Chưa có sản phẩm nào</h3>
                    <p class="font-body-md text-secondary">Vào Admin để thêm món đầu tiên cho menu.</p>
                    <a asp-action="Add" class="inline-flex mt-4 bg-primary text-on-primary px-6 py-3 rounded-full font-label-md text-decoration-none">Thêm sản phẩm</a>
                </div>
            }
        </section>
    <!-- Product Detail Modal -->
    <div class="fixed inset-0 z-[70] hidden items-center justify-center p-margin-mobile" id="detailModal">
        <div class="absolute inset-0 bg-primary/40 backdrop-blur-sm" onclick="closeDetail()"></div>
        <div class="relative bg-surface rounded-2xl max-w-4xl w-full overflow-hidden flex flex-col md:flex-row shadow-2xl scale-95 transition-transform duration-300" id="modalContent">
            <div class="md:w-1/2 h-64 md:h-auto overflow-hidden">
                <img class="w-full h-full object-cover" data-alt="A detailed, premium product shot focused on a specific beverage or food item from the menu. The lighting is artistic and controlled, emphasizing textures and colors. The background remains minimalist and on-brand, reflecting the Komorebi Brews aesthetic of light-filtered serenity and artisanal precision. Every element is presented with high-end digital design clarity." id="detailImg" src="/images/default-coffee.svg">
            </div>
            <div class="md:w-1/2 p-gutter flex flex-col justify-between">
                <div>
                    <div class="flex justify-between items-start mb-4">
                        <h2 class="font-display-lg text-headline-lg text-primary" id="detailTitle">Product Name</h2>
                        <button class="p-2 hover:bg-surface-container rounded-full" onclick="closeDetail()">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <p class="font-body-lg text-secondary mb-6" id="detailDescription">Món quà từ thiên nhiên với quy trình chế biến thủ công, giữ trọn vẹn hương vị nguyên bản nhất để đánh thức mọi giác quan của bạn.</p>
                    <div class="space-y-4 mb-8">
                        <div>
                            <span class="font-label-md text-primary block mb-2">Tùy chọn đường</span>
                            <div class="flex gap-2">
                                <button class="px-4 py-1 rounded-full border border-primary bg-primary text-on-primary font-caption">100%</button>
                                <button class="px-4 py-1 rounded-full border border-outline font-caption">50%</button>
                                <button class="px-4 py-1 rounded-full border border-outline font-caption">Không đường</button>
                            </div>
                        </div>
                        <div>
                            <span class="font-label-md text-primary block mb-2">Kích cỡ</span>
                            <div class="flex gap-2">
                                <button class="px-4 py-1 rounded-full border border-outline font-caption">Nhỏ</button>
                                <button class="px-4 py-1 rounded-full border border-primary bg-primary text-on-primary font-caption">Vừa</button>
                                <button class="px-4 py-1 rounded-full border border-outline font-caption">Lớn</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-primary font-headline-md" id="detailPrice">45.000 VNĐ</div>
                    <button type="button" id="addToCartBtn" class="flex-grow py-4 bg-primary text-on-primary font-label-md rounded-xl hover:shadow-lg transition-soft">Thêm vào giỏ hàng</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer -->
    <footer id="story" class="w-full mt-section-gap bg-surface-container py-section-gap px-margin-mobile md:px-margin-desktop flex flex-col items-center gap-gutter">
        <div class="flex items-center gap-3">
            <img src="/images/logo.svg" alt="Cherry Blossom Logo" class="h-12 w-auto">
            <span class="font-['Noto_Serif'] text-[32px] font-bold leading-none">
                <span style="color: #3e2723;" class="">Coffe</span><span style="color: #81c784;" class="">-latte</span><span style="color: #f48fb1;" class="">Kawaii</span>
            </span>
        </div>
        <div class="flex flex-wrap justify-center gap-gutter text-secondary">
            <a class="hover:text-on-tertiary-container transition-colors" href="#">Privacy Policy</a>
            <a class="hover:text-on-tertiary-container transition-colors" href="#">Terms of Service</a>
            <a class="hover:text-on-tertiary-container transition-colors" href="#">Shipping Info</a>
            <a class="hover:text-on-tertiary-container transition-colors" href="#">Contact Us</a>
        </div>
        <p class="font-body-md text-body-md text-secondary opacity-70">© 2024 Komorebi Brews. A Saigon-Kyoto Fusion.</p>
    </footer>
    <script>
        const currency = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 });
        let currentProduct = null;

        function toggleCart() {
            const drawer = document.getElementById('cartDrawer');
            drawer.classList.toggle('translate-x-full');
        }

        function getCart() {
            return JSON.parse(localStorage.getItem('kawaii_cart') || '[]');
        }

        function setCart(cart) {
            localStorage.setItem('kawaii_cart', JSON.stringify(cart));
        }

        function renderCart() {
            const cart = getCart();
            const countEl = document.getElementById('cartCount');
            const itemsEl = document.getElementById('cartItems');
            const totalEl = document.getElementById('cartTotal');
            if (countEl) countEl.textContent = cart.reduce((sum, item) => sum + item.qty, 0);
            if (totalEl) totalEl.textContent = currency.format(cart.reduce((sum, item) => sum + item.price * item.qty, 0));
            if (!itemsEl) return;
            itemsEl.innerHTML = cart.length
                ? cart.map(item => `<div class="flex gap-4"><div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0"><img class="w-full h-full object-cover" src="${item.image}" alt="${item.name}"></div><div class="flex-grow"><p class="font-label-md text-label-md text-primary">${item.name}</p><p class="font-caption text-caption text-secondary">Đã chọn</p><div class="flex justify-between items-center mt-2"><span class="font-body-md text-primary">${currency.format(item.price * item.qty)}</span><div class="flex items-center gap-2"><span>${item.qty}</span></div></div></div></div>`).join('')
                : '<p class="font-body-md text-secondary">Giỏ hàng đang trống.</p>';
        }

        function openDetailFromElement(element) {
            const modal = document.getElementById('detailModal');
            const modalContent = document.getElementById('modalContent');
            const detailTitle = document.getElementById('detailTitle');
            const detailImg = document.getElementById('detailImg');
            const detailDescription = document.getElementById('detailDescription');
            const detailPrice = document.getElementById('detailPrice');

            currentProduct = {
                name: element.dataset.name,
                description: element.dataset.description || 'Món quà từ thiên nhiên với quy trình chế biến thủ công, giữ trọn vẹn hương vị nguyên bản nhất để đánh thức mọi giác quan của bạn.',
                price: Number(element.dataset.price),
                displayPrice: element.dataset.displayPrice,
                image: element.dataset.image
            };

            detailTitle.innerText = currentProduct.name;
            detailDescription.innerText = currentProduct.description;
            detailPrice.innerText = currentProduct.displayPrice;
            detailImg.src = currentProduct.image;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }

        function closeDetail() {
            const modal = document.getElementById('detailModal');
            const modalContent = document.getElementById('modalContent');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 300);
        }

        document.querySelectorAll('.js-open-detail').forEach(element => {
            element.addEventListener('click', () => openDetailFromElement(element));
        });

        document.getElementById('addToCartBtn')?.addEventListener('click', () => {
            if (!currentProduct) return;
            const cart = getCart();
            const existing = cart.find(item => item.name === currentProduct.name);
            if (existing) existing.qty += 1;
            else cart.push({ name: currentProduct.name, price: currentProduct.price, image: currentProduct.image, qty: 1 });
            setCart(cart);
            renderCart();
            closeDetail();
            document.getElementById('cartDrawer').classList.remove('translate-x-full');
        });

        const slides = Array.from(document.querySelectorAll('#hero-slider .slide'));
        if (slides.length > 1) {
            let active = 0;
            setInterval(() => {
                slides[active].classList.replace('opacity-100', 'opacity-0');
                active = (active + 1) % slides.length;
                slides[active].classList.replace('opacity-0', 'opacity-100');
            }, 4500);
        }

        renderCart();
    </script>
