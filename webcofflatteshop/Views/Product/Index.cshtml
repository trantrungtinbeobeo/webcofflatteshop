    };
    var heroImage = banners.FirstOrDefault(b => !string.IsNullOrWhiteSpace(b)) ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuCYz6au7BPWgtSSBFiSZJVjAly8L00XGdg-tPC4829OE-DiHnKyKeSY6Mpr26uJoVFOx85UdexJd1d_f9NDIDLMgzO7koTOcWG6FRVJ-OVuTowfYg8k3u2Tp_uyWppOLMczAyclalIUQtggbC15NjCar30VXcyHovsL6YnJSPZIwk2FyHa5CzvUX4qe5cxy2HOC6SWqB7Oys46JRkS7e_o2dt8jPgAGTcwq3ONsQVlR-2338Ikw0xTyKzPDMKNG7dl33GDc4iNo8SE";
    string ImageOf(webcofflatteshop.Models.Product product, int index) => string.IsNullOrWhiteSpace(product.ImageUrl) ? fallbackImages[index % fallbackImages.Length] : product.ImageUrl;
    string IconOf(string name)
    {
        var lower = name.ToLowerInvariant();
        if (lower.Contains("matcha") || lower.Contains("trà") || lower.Contains("tea")) return "energy_savings_leaf";
        if (lower.Contains("bánh") || lower.Contains("cake")) return "cake";
        if (lower.Contains("croissant")) return "bakery_dining";
        if (lower.Contains("espresso")) return "bolt";
        if (lower.Contains("atiso") || lower.Contains("ice")) return "icecream";
        return "coffee";
    }
}

<nav class="sticky top-0 z-50 bg-surface shadow-[0_10px_30px_rgba(62,39,35,0.05)]">
    <div class="mx-auto flex w-full max-w-container-max items-center justify-between px-margin-mobile py-unit md:px-margin-desktop">
        <a asp-controller="Product" asp-action="Index" class="flex items-center gap-3">
            <span class="brand-blossom" aria-hidden="true">✼</span>
            <h1 class="font-['Noto_Serif'] text-[32px] font-bold leading-none">
                <span style="color:#3e2723">Coffe</span><span style="color:#81c784">-latte</span><span style="color:#f48fb1">Kawaii</span>
            </h1>
        </a>
        <div class="hidden items-center gap-gutter md:flex">
            <a class="font-body-md border-b-2 border-primary pb-1 text-primary" href="#menu">Menu</a>
            <a class="font-body-md text-secondary transition-colors duration-200 hover:text-primary" asp-controller="Product" asp-action="Add">Manager</a>
        </div>
        <div class="flex items-center gap-unit">
            <button class="relative rounded-full p-2 text-primary transition-colors hover:bg-secondary-container" onclick="toggleCart()" aria-label="Mở giỏ hàng">
                <span class="material-symbols-outlined">shopping_cart</span>
                <span id="cartCount" class="absolute right-0 top-0 flex h-4 w-4 items-center justify-center rounded-full bg-primary text-[10px] text-white">0</span>
            </button>
            <button class="p-2 text-primary md:hidden" aria-label="Menu">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>
</nav>

<div id="cartDrawer" class="fixed right-0 top-0 z-[60] flex h-full w-full translate-x-full flex-col bg-surface-container-lowest shadow-2xl transition-transform duration-300 lg:w-[400px] lg:translate-x-0">
    <div class="flex items-center justify-between border-b border-outline-variant p-gutter">
        <div>
            <h2 class="font-headline-md text-headline-md text-primary">Your Selection</h2>
            <p class="font-caption text-caption text-secondary">Carefully crafted for you</p>
        </div>
        <button class="rounded-full p-2 hover:bg-surface-container" onclick="toggleCart()" aria-label="Đóng giỏ hàng">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
    <div id="cartItems" class="flex-grow space-y-gutter overflow-y-auto p-gutter"></div>
    <div class="space-y-4 border-t border-outline-variant bg-surface-container p-gutter">
        <div class="flex justify-between font-label-md text-label-md text-primary">
            <span>Subtotal</span>
            <span id="cartSubtotal">0 VNĐ</span>
        </div>
        <button id="checkoutBtn" class="flex w-full items-center justify-between rounded-lg bg-primary px-6 py-4 font-label-md text-on-primary transition-soft hover:brightness-110">
            <span>Proceed to Checkout</span>
            <span class="material-symbols-outlined">arrow_forward</span>
        </button>
    </div>
</div>

<main class="mx-auto max-w-container-max px-margin-mobile py-gutter md:px-margin-desktop lg:mr-[400px]">
    <section class="group relative mb-section-gap h-[400px] overflow-hidden rounded-xl">
        <div class="relative h-full overflow-hidden">
            <img class="h-full w-full object-cover" src="@heroImage" alt="Coffee hero" />
            <div class="hero-gradient absolute inset-0 flex items-end p-gutter">
                <div class="max-w-xl text-white">
                    <h1 class="mb-4 font-display-lg text-display-lg">Hương Vị Nghệ Thuật</h1>
                    <p class="font-body-lg text-body-lg opacity-90">Sự kết hợp hoàn hảo giữa tâm hồn Sài Gòn và hơi thở cố đô Kyoto.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="hide-scrollbar mb-gutter flex gap-4 overflow-x-auto py-2">
        <button class="category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container" data-category-id="1">Coffee (Cà Phê)</button>
        <button class="category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container" data-category-id="2">Matcha (Trà Xanh)</button>
        <button class="category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container" data-category-id="3">Chocolate (Sô-cô-la)</button>
        <button class="category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container" data-category-id="4">Bakery (Bánh Ngọt)</button>
    </section>

    <section id="menu" class="grid grid-cols-1 gap-gutter md:grid-cols-2 lg:grid-cols-3">
        @for (var index = 0; index < products.Count; index++)
        {
            var product = products[index];
            var imageUrl = ImageOf(product, index);
            <article class="product-card group overflow-hidden rounded-xl bg-surface-container-lowest shadow-[0_10px_30px_rgba(62,39,35,0.05)] transition-soft hover:-translate-y-1 hover:shadow-xl" data-category-id="@product.CategoryId">
                <button type="button" class="js-open-detail block w-full text-left" data-name="@product.Name" data-description="@product.Description" data-price="@product.Price.ToString("0.00")" data-display-price="@product.Price.ToString("N0") VNĐ" data-image="@imageUrl">
                    <div class="relative aspect-square cursor-pointer overflow-hidden">
                        <img class="h-full w-full object-cover transition-soft group-hover:scale-105" src="@imageUrl" alt="@product.Name" />
                        <div class="absolute right-4 top-4 rounded-full bg-white/80 p-2 backdrop-blur-md">
                            <span class="material-symbols-outlined text-primary">@IconOf(product.Name)</span>
                        </div>
                    </div>
                    <div class="p-gutter">
                        <h3 class="mb-1 font-headline-md text-headline-md text-primary">@product.Name</h3>
                        <p class="mb-4 line-clamp-2 font-body-md text-secondary">@product.Description</p>
                        <div class="flex items-center justify-between gap-3">
                            <span class="font-label-md text-lg text-on-tertiary-container">@product.Price.ToString("N0") VNĐ</span>
                            <span class="rounded-lg bg-primary px-4 py-2 font-label-md text-on-primary transition-soft hover:brightness-125">Thêm vào giỏ</span>
                        </div>
                    </div>
                </button>
            </article>
        }
    </section>
</main>

<div id="detailModal" class="fixed inset-0 z-[70] hidden items-center justify-center p-margin-mobile">
    <div class="absolute inset-0 bg-primary/40 backdrop-blur-sm" onclick="closeDetail()"></div>
    <div id="modalContent" class="relative flex w-full max-w-4xl scale-95 flex-col overflow-hidden rounded-2xl bg-surface shadow-2xl transition-transform duration-300 md:flex-row">
        <div class="h-64 overflow-hidden md:h-auto md:w-1/2">
            <img id="detailImg" class="h-full w-full object-cover" src="/images/default-coffee.svg" alt="Product detail" />
        </div>
        <div class="flex flex-col justify-between p-gutter md:w-1/2">
            <div>
                <div class="mb-4 flex items-start justify-between">
                    <h2 id="detailTitle" class="font-display-lg text-headline-lg text-primary">Product Name</h2>
                    <button class="rounded-full p-2 hover:bg-surface-container" onclick="closeDetail()">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <p id="detailDesc" class="mb-6 font-body-lg text-secondary">Món quà từ thiên nhiên với quy trình chế biến thủ công.</p>
                <div class="mb-8 space-y-4">
                    <div>
                        <span class="mb-2 block font-label-md text-primary">Tùy chọn đường</span>
                        <div class="flex gap-2">
                            <button class="sugar-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary" data-sugar="100%">100%</button>
                            <button class="sugar-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary" data-sugar="50%">50%</button>
                            <button class="sugar-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary" data-sugar="Không đường">Không đường</button>
                        </div>
                    </div>
                    <div>
                        <span class="mb-2 block font-label-md text-primary">Kích cỡ</span>
                        <div class="flex gap-2">
                            <button class="size-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary" data-size="Nhỏ">Nhỏ</button>
                            <button class="size-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary" data-size="Vừa">Vừa</button>
                            <button class="size-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary" data-size="Lớn">Lớn</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div id="detailPrice" class="font-headline-md text-primary">45.000 VNĐ</div>
                <button id="detailAddBtn" class="flex-grow rounded-xl bg-primary py-4 font-label-md text-on-primary transition-soft hover:shadow-lg">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>
</div>

<footer id="story" class="mt-section-gap flex w-full flex-col items-center gap-gutter bg-surface-container px-margin-mobile py-section-gap md:px-margin-desktop lg:mr-[400px]">
    <div class="flex items-center gap-3">
        <span class="brand-blossom" aria-hidden="true">✼</span>
        <span class="font-['Noto_Serif'] text-[32px] font-bold leading-none">
            <span style="color:#3e2723">Coffe</span><span style="color:#81c784">-latte</span><span style="color:#f48fb1">Kawaii</span>
        </span>
    </div>
    <div class="flex flex-wrap justify-center gap-gutter text-secondary">
        <a class="transition-colors hover:text-on-tertiary-container" href="#">Privacy Policy</a>
        <a class="transition-colors hover:text-on-tertiary-container" href="#">Terms of Service</a>
        <a class="transition-colors hover:text-on-tertiary-container" href="#">Shipping Info</a>
        <a class="transition-colors hover:text-on-tertiary-container" href="#">Contact Us</a>
    </div>
    <p class="font-body-md text-body-md text-secondary opacity-70">© 2024 Komorebi Brews. A Saigon-Kyoto Fusion.</p>
</footer>

@section Scripts {
<script>
(() => {
    const formatCurrency = value => `${Number(value || 0).toLocaleString('vi-VN')} VNĐ`;
    const getCart = () => JSON.parse(localStorage.getItem('coffee_cart') || '[]');
    const setCart = value => localStorage.setItem('coffee_cart', JSON.stringify(value));
    const cartDrawer = document.getElementById('cartDrawer');
    const cartCount = document.getElementById('cartCount');
    const cartItems = document.getElementById('cartItems');
    const cartSubtotal = document.getElementById('cartSubtotal');
    let current = null;
    let selectedSugar = "100%";
    let selectedSize = "Vừa";

    window.toggleCart = () => cartDrawer.classList.toggle('translate-x-full');
    window.closeDetail = () => {
        document.getElementById('detailModal').classList.add('hidden');
        document.getElementById('detailModal').classList.remove('flex');
    };

    const renderCart = () => {
        const cart = getCart();
        cartCount.textContent = cart.reduce((sum, item) => sum + item.qty, 0);
        cartSubtotal.textContent = formatCurrency(cart.reduce((sum, item) => sum + item.price * item.qty, 0));
        cartItems.innerHTML = cart.length
            ? cart.map(item => `
                <div class="flex gap-4 border-b border-outline-variant/10 pb-3">
                    <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-lg">
                        <img class="h-full w-full object-cover" src="${item.image}" alt="${item.name}">
                    </div>
                    <div class="flex-grow">
                        <p class="font-label-md text-label-md text-primary font-semibold">${item.name}</p>
                        <p class="text-[12px] text-secondary mt-0.5">Size: ${item.size} | Đường: ${item.sugar}</p>
                        <p class="font-caption text-caption text-secondary">Số lượng: ${item.qty}</p>
                        <div class="mt-1 flex items-center justify-between">
                            <span class="font-body-md text-primary font-medium">${formatCurrency(item.price * item.qty)}</span>
                        </div>
                    </div>
                </div>`).join('')
            : '<p class="font-body-md text-secondary">Chưa có sản phẩm nào.</p>';
    };

    const addToCart = item => {
        const cart = getCart();
        const index = cart.findIndex(entry => entry.name === item.name && entry.sugar === item.sugar && entry.size === item.size);
        if (index >= 0) cart[index].qty += 1;
        else cart.push({ ...item, qty: 1 });
        setCart(cart);
        renderCart();
    };

    // Chi tiết sản phẩm & Lựa chọn thuộc tính
    document.querySelectorAll('.js-open-detail').forEach(button => {
        button.addEventListener('click', () => {
            const basePrice = Number(button.dataset.price) * 10000; // Đưa về đơn vị VNĐ chính xác (ví dụ 2.50m tương đương 25.000 VNĐ)
            current = { 
                name: button.dataset.name, 
                basePrice: basePrice,
                price: basePrice, 
                image: button.dataset.image 
            };

            document.getElementById('detailTitle').textContent = button.dataset.name;
            document.getElementById('detailDesc').textContent = button.dataset.description || 'Món quà từ thiên nhiên với quy trình chế biến thủ công.';
            
            // Khởi tạo trạng thái mặc định
            selectedSugar = "100%";
            selectedSize = "Vừa";
            updateDetailPrice();

            // Reset classes cho Đường
            document.querySelectorAll('.sugar-option-btn').forEach(btn => {
                if (btn.dataset.sugar === "100%") {
                    btn.className = "sugar-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary";
                } else {
                    btn.className = "sugar-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary";
                }
            });

            // Reset classes cho Size
            document.querySelectorAll('.size-option-btn').forEach(btn => {
                if (btn.dataset.size === "Vừa") {
                    btn.className = "size-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary";
                } else {
                    btn.className = "size-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary";
                }
            });

            document.getElementById('detailImg').src = button.dataset.image;
            document.getElementById('detailModal').classList.remove('hidden');
            document.getElementById('detailModal').classList.add('flex');
        });
    });

    const updateDetailPrice = () => {
        if (!current) return;
        let finalPrice = current.basePrice;
        if (selectedSize === "Nhỏ") finalPrice -= 5000;
        else if (selectedSize === "Lớn") finalPrice += 10000;
        
        current.price = finalPrice;
        document.getElementById('detailPrice').textContent = formatCurrency(finalPrice);
    };

    // Click chọn Đường
    document.querySelectorAll('.sugar-option-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            selectedSugar = btn.dataset.sugar;
            document.querySelectorAll('.sugar-option-btn').forEach(b => {
                if (b === btn) {
                    b.className = "sugar-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary";
                } else {
                    b.className = "sugar-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary";
                }
            });
        });
    });

    // Click chọn Size
    document.querySelectorAll('.size-option-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            selectedSize = btn.dataset.size;
            document.querySelectorAll('.size-option-btn').forEach(b => {
                if (b === btn) {
                    b.className = "size-option-btn rounded-full border border-primary bg-primary px-4 py-1 font-caption text-on-primary";
                } else {
                    b.className = "size-option-btn rounded-full border border-outline px-4 py-1 font-caption text-secondary";
                }
            });
            updateDetailPrice();
        });
    });

    document.getElementById('detailAddBtn').addEventListener('click', () => {
        if (current) {
            addToCart({
                name: current.name,
                price: current.price,
                image: current.image,
                sugar: selectedSugar,
                size: selectedSize
            });
        }
        closeDetail();
    });

    // Lọc danh mục Client-side
    const categoryBtns = document.querySelectorAll('.category-btn');
    const productCards = document.querySelectorAll('.product-card');
    let activeCategoryId = null;

    categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const categoryId = btn.dataset.categoryId;
            if (activeCategoryId === categoryId) {
                // Hủy chọn, hiện lại tất cả
                activeCategoryId = null;
                categoryBtns.forEach(b => {
                    b.className = "category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container";
                });
                productCards.forEach(c => c.classList.remove('hidden'));
            } else {
                activeCategoryId = categoryId;
                categoryBtns.forEach(b => {
                    if (b === btn) {
                        b.className = "category-btn whitespace-nowrap rounded-full bg-primary px-6 py-2 font-label-md text-on-primary transition-soft";
                    } else {
                        b.className = "category-btn whitespace-nowrap rounded-full border border-outline bg-surface px-6 py-2 font-label-md text-primary transition-soft hover:bg-secondary-container";
                    }
                });
                productCards.forEach(c => {
                    if (c.dataset.categoryId === categoryId) {
                        c.classList.remove('hidden');
                    } else {
                        c.classList.add('hidden');
                    }
                });
            }
        });
    });

    // Xử lý sự kiện Checkout (đặt hàng) giảm Stock ở database
    document.getElementById('checkoutBtn').addEventListener('click', async () => {
        const cart = getCart();
        if (!cart.length) {
            alert("Giỏ hàng của bạn đang trống. Vui lòng thêm sản phẩm!");
            return;
        }

        try {
            const response = await fetch('/Product/Checkout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    items: cart.map(item => ({
                        name: item.name,
                        qty: item.qty
                    }))
                })
            });

            const result = await response.json();
            if (response.ok && result.success) {
                alert(result.message);
                localStorage.removeItem('coffee_cart');
                renderCart();
                toggleCart();
            } else {
                alert(result.message || "Đặt hàng thất bại. Vui lòng thử lại!");
            }
        } catch (error) {
            console.error("Lỗi đặt hàng:", error);
            alert("Có lỗi xảy ra khi kết nối máy chủ. Vui lòng thử lại!");
        }
    });

    renderCart();
})();
</script>
}
