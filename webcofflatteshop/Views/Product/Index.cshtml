@model IEnumerable<webcofflatteshop.Models.Product>
@using System.Globalization
@{
    ViewData["Title"] = "Menu";
    ViewData["UseStitcheditLayout"] = true;
    var products = Model?.ToList() ?? new List<webcofflatteshop.Models.Product>();
    var banners = (ViewBag.Banners as IEnumerable<string>)?.Where(b => !string.IsNullOrWhiteSpace(b)).ToList() ?? new List<string>();
    if (!banners.Any()) banners.Add("/images/default-coffee.svg");
    var categories = products.Select(p => p.Category?.Name).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().ToList();
    string FormatPrice(decimal price) => string.Format(CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} VNĐ", price);
    string DataPrice(decimal price) => price.ToString(CultureInfo.InvariantCulture);
    string ImageOf(webcofflatteshop.Models.Product p) => string.IsNullOrWhiteSpace(p.ImageUrl) ? "/images/default-coffee.svg" : p.ImageUrl;
}

    <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-gutter">
        <!-- Hero Carousel -->
        <section class="relative rounded-xl overflow-hidden h-[400px] mb-section-gap group">
            @foreach (var banner in banners.Select((url, index) => new { url, index }))
            {
                <div class="hero-panel absolute inset-0 transition-opacity duration-700 @(banner.index == 0 ? "opacity-100" : "opacity-0")">
                    <img class="w-full h-full object-cover" alt="Coffee shop hero @(banner.index + 1)" src="@banner.url">
                    <div class="hero-gradient absolute inset-0"></div>
                </div>
            }
            <div class="absolute bottom-0 left-0 p-gutter md:p-margin-desktop max-w-2xl">
                <span class="inline-block bg-primary-fixed text-on-primary-fixed px-4 py-2 rounded-full font-label-md text-label-md mb-4">Saigon-Kyoto Fusion</span>
                <h2 class="font-display-lg text-display-lg text-white mb-4 drop-shadow-md">Cà phê Việt, nét Kawaii Nhật Bản.</h2>
                <p class="font-body-lg text-body-lg text-white/90 mb-6">Những ly cà phê latte mềm mại, matcha tươi và bánh ngọt được sắp đặt đúng tinh thần bản thiết kế bạn đã edit.</p>
                <a href="#menu" class="bg-surface text-primary px-6 py-3 rounded-full font-label-md hover:bg-primary-fixed transition-colors text-decoration-none inline-flex">Khám phá Menu</a>
            </div>
        </section>

        <!-- Category Pills -->
        <section class="flex gap-4 overflow-x-auto hide-scrollbar mb-gutter py-2">
            <button class="px-6 py-3 rounded-full bg-primary text-on-primary font-label-md whitespace-nowrap shadow-md">Tất cả</button>
            @foreach (var category in categories)
            {
                <button class="px-6 py-3 rounded-full bg-surface-container-low text-primary font-label-md whitespace-nowrap hover:bg-secondary-container transition-colors">@category</button>
            }
            @if (!categories.Any())
            {
                <button class="px-6 py-3 rounded-full bg-surface-container-low text-primary font-label-md whitespace-nowrap">Cà phê Việt Nam</button>
                <button class="px-6 py-3 rounded-full bg-surface-container-low text-primary font-label-md whitespace-nowrap">Trà &amp; Matcha</button>
                <button class="px-6 py-3 rounded-full bg-surface-container-low text-primary font-label-md whitespace-nowrap">Bánh ngọt</button>
            }
        </section>

        <!-- Product Grid -->
        <section id="menu" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
            @foreach (var product in products)
            {
                var imageUrl = ImageOf(product);
                <article class="product-card group bg-surface-container-lowest rounded-xl overflow-hidden custom-shadow hover:shadow-xl transition-soft">
                    <div class="relative h-64 overflow-hidden cursor-pointer js-open-detail" data-name="@product.Name" data-description="@product.Description" data-price="@DataPrice(product.Price)" data-display-price="@FormatPrice(product.Price)" data-image="@imageUrl">
                        <img class="w-full h-full object-cover" alt="@product.Name" src="@imageUrl">
                        <div class="absolute top-4 left-4 bg-surface/90 backdrop-blur-sm px-3 py-1 rounded-full">
                            <span class="font-caption text-caption text-primary">@(product.Category?.Name ?? "Signature")</span>
                        </div>
                    </div>
                    <div class="p-gutter">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-headline-md text-headline-md text-primary m-0">@product.Name</h3>
                            <span class="font-label-md text-primary whitespace-nowrap">@FormatPrice(product.Price)</span>
                        </div>
                        <p class="font-body-md text-body-md text-secondary mb-4 min-h-[48px]">@product.Description</p>
                        <button type="button" class="js-open-detail w-full py-3 border border-primary text-primary rounded-full font-label-md hover:bg-primary hover:text-on-primary transition-colors flex items-center justify-center gap-2" data-name="@product.Name" data-description="@product.Description" data-price="@DataPrice(product.Price)" data-display-price="@FormatPrice(product.Price)" data-image="@imageUrl">
                            Thêm vào giỏ
                            <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                        </button>
                    </div>
                </article>
            }
            @if (!products.Any())
            {
                <div class="md:col-span-2 lg:col-span-3 bg-surface-container-lowest rounded-xl p-gutter text-center custom-shadow">
                    <h3 class="font-headline-md text-primary">Chưa có sản phẩm nào</h3>
                    <p class="text-secondary">Vào Admin để thêm món đầu tiên cho menu.</p>
                    <a asp-action="Add" class="inline-flex mt-4 bg-primary text-on-primary px-6 py-3 rounded-full font-label-md text-decoration-none">Thêm sản phẩm</a>
                </div>
            }
        </section>
    </main>

    <!-- Product Detail Modal -->
    <div class="fixed inset-0 bg-primary/60 z-[70] hidden items-center justify-center p-margin-mobile" id="productModal">
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden max-w-[900px] w-full custom-shadow grid grid-cols-1 md:grid-cols-2">
            <div class="h-[320px] md:h-auto overflow-hidden">
                <img id="modalProductImage" class="w-full h-full object-cover" src="/images/default-coffee.svg" alt="Product detail">
            </div>
            <div class="p-gutter md:p-margin-desktop">
                <div class="flex justify-between items-start gap-4 mb-4">
                    <div>
                        <p class="font-label-md text-secondary mb-2">Chi tiết món</p>
                        <h3 id="modalProductName" class="font-headline-lg text-headline-lg text-primary m-0"></h3>
                    </div>
                    <button type="button" class="p-2 hover:bg-surface-container rounded-full" onclick="closeProductModal()"><span class="material-symbols-outlined">close</span></button>
                </div>
                <p id="modalProductDesc" class="font-body-md text-secondary mb-6"></p>
                <p id="modalProductPrice" class="font-headline-md text-primary mb-6"></p>
                <label class="block font-label-md text-secondary mb-2" for="modalQty">Số lượng</label>
                <div class="flex gap-3">
                    <input id="modalQty" type="number" min="1" value="1" class="w-28 rounded-lg border-outline-variant bg-white px-4 py-3 text-body-md focus:border-primary focus:ring-primary">
                    <button id="addToCartBtn" type="button" class="flex-1 bg-primary text-on-primary rounded-full font-label-md hover:bg-primary-container transition-colors">Thêm vào giỏ</button>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
<script>
    const currency = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 });
    let currentProduct = null;

    function toggleCart() {
        document.getElementById('cartDrawer').classList.toggle('translate-x-full');
    }

    function closeProductModal() {
        const modal = document.getElementById('productModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }

    function getCart() {
        return JSON.parse(localStorage.getItem('kawaii_cart') || '[]');
    }

    function setCart(cart) {
        localStorage.setItem('kawaii_cart', JSON.stringify(cart));
    }

    function renderCart() {
        const cart = getCart();
        document.getElementById('cartCount').textContent = cart.reduce((sum, item) => sum + item.qty, 0);
        document.getElementById('cartTotal').textContent = currency.format(cart.reduce((sum, item) => sum + item.price * item.qty, 0));
        document.getElementById('cartItems').innerHTML = cart.length
            ? cart.map(item => `<div class="flex gap-4"><div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0"><img class="w-full h-full object-cover" src="${item.image}" alt="${item.name}"></div><div class="flex-grow"><p class="font-label-md text-label-md text-primary mb-1">${item.name}</p><p class="font-caption text-caption text-secondary mb-2">Số lượng: ${item.qty}</p><div class="flex justify-between items-center"><span class="font-body-md text-primary">${currency.format(item.price * item.qty)}</span></div></div></div>`).join('')
            : '<p class="text-body-md text-secondary">Giỏ hàng đang trống.</p>';
    }

    document.querySelectorAll('.hero-panel').forEach((panel, index, panels) => {
        if (panels.length <= 1 || index !== 0) return;
        let active = 0;
        setInterval(() => {
            panels[active].classList.replace('opacity-100', 'opacity-0');
            active = (active + 1) % panels.length;
            panels[active].classList.replace('opacity-0', 'opacity-100');
        }, 4500);
    });

    document.querySelectorAll('.js-open-detail').forEach(button => {
        button.addEventListener('click', () => {
            currentProduct = {
                name: button.dataset.name,
                price: Number(button.dataset.price),
                image: button.dataset.image
            };
            document.getElementById('modalProductName').textContent = button.dataset.name;
            document.getElementById('modalProductDesc').textContent = button.dataset.description || 'Món ngon được pha chế mỗi ngày.';
            document.getElementById('modalProductPrice').textContent = button.dataset.displayPrice;
            document.getElementById('modalProductImage').src = button.dataset.image;
            document.getElementById('modalQty').value = 1;
            const modal = document.getElementById('productModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });
    });

    document.getElementById('productModal').addEventListener('click', event => {
        if (event.target.id === 'productModal') closeProductModal();
    });

    document.getElementById('addToCartBtn').addEventListener('click', () => {
        if (!currentProduct) return;
        const qty = Math.max(1, Number.parseInt(document.getElementById('modalQty').value || '1', 10));
        const cart = getCart();
        const existing = cart.find(item => item.name === currentProduct.name);
        if (existing) existing.qty += qty;
        else cart.push({ ...currentProduct, qty });
        setCart(cart);
        renderCart();
        closeProductModal();
        document.getElementById('cartDrawer').classList.remove('translate-x-full');
    });

    renderCart();
</script>
}
