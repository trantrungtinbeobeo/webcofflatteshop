@model webcofflatteshop.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="card coffee-card p-4 shadow-sm">
    <div class="row g-4 align-items-center">
        <div class="col-md-5">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/default-coffee.svg" : Model.ImageUrl)" class="detail-image" alt="@Model.Name" />
        </div>
        <div class="col-md-7">
            <h2>@Model.Name</h2>
            <p class="lead text-muted">@Model.Description</p>
            <p class="product-price">@Model.Price.ToString("C")</p>

            <form class="d-flex align-items-end gap-2 mb-3">
                <div>
                    <label class="form-label">Số lượng</label>
                    <input type="number" class="form-control" min="1" value="1" />
                </div>
                <button type="button" class="btn btn-coffee">Đặt hàng</button>
            </form>

            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Về danh sách</a>
            </div>
        </div>
    </div>
</div>
