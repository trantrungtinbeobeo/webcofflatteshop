@model IEnumerable<webcofflatteshop.Models.Product>
@{
    ViewData["Title"] = "Quản lý upload ảnh";
}

<h2 class="mb-4">Chọn sản phẩm để upload ảnh</h2>
<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card coffee-card h-100 shadow-sm product-hover">
                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/default-coffee.svg" : product.ImageUrl)" class="card-img-top product-image" alt="@product.Name"/>
                <div class="card-body">
                    <h5>@product.Name</h5>
                    <p class="text-muted">@product.Description</p>
                    <a asp-action="UploadImage" asp-route-id="@product.Id" class="btn btn-success">Upload ảnh cho sản phẩm này</a>
                </div>
            </div>
        </div>
    }
</div>
