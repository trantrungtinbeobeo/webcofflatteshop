@model IEnumerable<webcofflatteshop.Models.Product>
@{
    ViewData["Title"] = "Quản lý ảnh sản phẩm";
    var banners = ViewBag.UploadBanners as IEnumerable<string> ?? new[] { "/images/default-coffee.svg" };
}

@if (TempData["BannerSuccess"] is string ok)
{<div class="alert alert-success">@ok</div>}
@if (TempData["BannerError"] is string err)
{<div class="alert alert-danger">@err</div>}

<div id="uploadBanner" class="carousel slide mb-4 rounded-banner overflow-hidden" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-inner banner-inner">
        @{ var i = 0; }
        @foreach (var banner in banners)
        {
            <div class="carousel-item @(i == 0 ? "active" : "")"><img src="@banner" class="d-block w-100 banner-image" alt="Banner @(i+1)" /></div>
            i++;
        }
    </div>
</div>

<div class="card coffee-card p-4 mb-4">
    <h4 class="mb-3">Upload Banner Marketing</h4>
    <div class="d-flex flex-wrap gap-3">
        <form asp-action="UploadBannerImage" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
            <input type="hidden" name="target" value="home" />
            <input type="file" name="bannerFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.svg" required />
            <button type="submit" class="btn btn-coffee">Upload banner Trang chủ</button>
        </form>
        <form asp-action="UploadBannerImage" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
            <input type="hidden" name="target" value="upload" />
            <input type="file" name="bannerFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.svg" required />
            <button type="submit" class="btn btn-outline-dark">Upload banner trang Upload</button>
        </form>
    </div>
</div>

<div class="row g-4">
@foreach (var product in Model){<div class="col-12 col-md-6 col-xl-4"><div class="card coffee-card h-100 shadow-sm product-hover upload-card"><img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/default-coffee.svg" : product.ImageUrl)" class="card-img-top product-image" alt="@product.Name" /><div class="card-body d-flex flex-column"><h5>@product.Name</h5><p class="text-muted flex-grow-1">@product.Description</p><div class="d-flex justify-content-between align-items-center mt-2"><span class="fw-semibold product-price">@product.Price.ToString("C")</span><a asp-action="UploadImage" asp-route-id="@product.Id" class="btn btn-success btn-sm">Chọn & Upload</a></div></div></div></div>}
</div>
