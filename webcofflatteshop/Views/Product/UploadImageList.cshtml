@model IEnumerable<webcofflatteshop.Models.Product>
@{
    ViewData["Title"] = "Quản lý ảnh sản phẩm";
}

<div id="uploadBanner" class="carousel slide mb-4 rounded-banner overflow-hidden" data-bs-ride="carousel" data-bs-interval="2800">
    <div class="carousel-inner banner-inner">
        <div class="carousel-item active">
            <img src="/images/default-coffee.svg" class="d-block w-100 banner-image" alt="Upload Banner 1" />
            <div class="carousel-caption text-start">
                <h3>Cập nhật hình ảnh sản phẩm</h3>
                <p>Hình đẹp giúp tăng tỉ lệ mua hàng.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="/images/default-coffee.svg" class="d-block w-100 banner-image" alt="Upload Banner 2" />
            <div class="carousel-caption text-start">
                <h3>Đồng bộ nhận diện menu</h3>
                <p>Giữ chất lượng ảnh nhất quán cho toàn bộ sản phẩm.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card coffee-card h-100 shadow-sm product-hover upload-card">
                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/default-coffee.svg" : product.ImageUrl)" class="card-img-top product-image" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <h5>@product.Name</h5>
                    <p class="text-muted flex-grow-1">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="fw-semibold product-price">@product.Price.ToString("C")</span>
                        <a asp-action="UploadImage" asp-route-id="@product.Id" class="btn btn-success btn-sm">Chọn & Upload</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
