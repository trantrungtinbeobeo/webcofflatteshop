@{
    var useStitcheditLayout = ViewData["UseStitcheditLayout"] is bool enabled && enabled;
    var useAdminStitcheditLayout = ViewData["UseAdminStitcheditLayout"] is bool adminEnabled && adminEnabled;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cozy Coffee Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@600;700&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script src="~/js/tailwind-config.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="@(useStitcheditLayout || useAdminStitcheditLayout ? "bg-background font-body-md text-on-background selection:bg-primary-fixed" : "app-shell d-flex flex-column")">
@if (useStitcheditLayout)
{
    <nav class="sticky top-0 z-50 bg-surface shadow-[0_10px_30px_rgba(62,39,35,0.05)]">
        <div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-unit max-w-container-max mx-auto">
            <a asp-controller="Product" asp-action="Index" class="flex items-center gap-unit text-decoration-none">
                <div class="flex items-center gap-3">
                    <img src="~/images/logo.svg" alt="Cherry Blossom Logo" class="h-10 w-auto">
                    <h1 class="font-['Noto_Serif'] text-[32px] font-bold leading-none m-0">
                        <span style="color: #3e2723;">Coffe</span><span style="color: #81c784;">-latte</span><span style="color: #f48fb1;">Kawaii</span>
                    </h1>
                </div>
            </a>
            <div class="hidden md:flex gap-gutter items-center">
                <a class="font-body-md text-primary border-b-2 border-primary pb-1 text-decoration-none" asp-controller="Product" asp-action="Index">Menu</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" href="#story">Our Story</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" asp-controller="Product" asp-action="Add">Admin</a>
                <a class="font-body-md text-secondary hover:text-primary transition-colors duration-200 text-decoration-none" asp-controller="Product" asp-action="UploadImageList">Media</a>
            </div>
            <div class="flex items-center gap-unit">
                <button class="relative p-2 text-primary hover:bg-secondary-container rounded-full transition-colors" type="button" onclick="toggleCart()">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span id="cartCount" class="absolute top-0 right-0 bg-primary text-white text-[10px] w-4 h-4 flex items-center justify-center rounded-full">0</span>
                </button>
                <button class="md:hidden p-2 text-primary" type="button">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </nav>

    <div class="fixed right-0 top-0 h-full w-full md:w-[400px] bg-surface-container-lowest shadow-2xl z-[60] translate-x-full transition-transform duration-300 flex flex-col" id="cartDrawer">
        <div class="p-gutter flex justify-between items-center border-b border-outline-variant">
            <div>
                <h2 class="font-headline-md text-headline-md text-primary m-0">Your Selection</h2>
                <p class="font-caption text-caption text-secondary m-0">Carefully crafted for you</p>
            </div>
            <button class="p-2 hover:bg-surface-container rounded-full" type="button" onclick="toggleCart()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div id="cartItems" class="flex-grow overflow-y-auto p-gutter space-y-gutter"></div>
        <div class="p-gutter border-t border-outline-variant bg-surface">
            <div class="flex justify-between mb-4 font-label-md text-primary">
                <span>Tổng cộng</span>
                <span id="cartTotal">0 VNĐ</span>
            </div>
            <button type="button" class="w-full bg-primary text-on-primary py-4 rounded-full font-label-md hover:bg-primary-container transition-colors">Thanh toán</button>
        </div>
    </div>

    @RenderBody()

    <footer id="story" class="w-full mt-section-gap bg-surface-container py-section-gap px-margin-mobile md:px-margin-desktop flex flex-col items-center gap-gutter">
        <div class="flex items-center gap-3">
            <img src="~/images/logo.svg" alt="Cherry Blossom Logo" class="h-12 w-auto">
            <span class="font-['Noto_Serif'] text-[32px] font-bold leading-none">
                <span style="color: #3e2723;">Coffe</span><span style="color: #81c784;">-latte</span><span style="color: #f48fb1;">Kawaii</span>
            </span>
        </div>
        <div class="flex flex-wrap justify-center gap-gutter text-secondary">
            <a class="hover:text-on-tertiary-container transition-colors text-decoration-none" href="#">Privacy Policy</a>
            <a class="hover:text-on-tertiary-container transition-colors text-decoration-none" href="#">Terms of Service</a>
            <a class="hover:text-on-tertiary-container transition-colors text-decoration-none" href="#">Shipping Info</a>
            <a class="hover:text-on-tertiary-container transition-colors text-decoration-none" href="#">Contact Us</a>
        </div>
        <p class="font-body-md text-body-md text-secondary opacity-70">© 2024 Komorebi Brews. A Saigon-Kyoto Fusion.</p>
    </footer>
}
else if (useAdminStitcheditLayout)
{
    @RenderBody()
}
else
{
    <div class="coffee-particles" aria-hidden="true"><span>☕</span><span>🫘</span><span>☕</span><span>🫘</span><span>☕</span><span>🫘</span></div>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold brand-float" asp-controller="Product" asp-action="Index">☕ Cozy Coffee Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"><span class="navbar-toggler-icon"></span></button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Coffee Shop</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Add">Thêm sản phẩm & danh mục</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="UploadImageList">Media Upload</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="app-main container flex-grow-1">@RenderBody()</main>
    <footer class="app-footer text-light mt-auto"><div class="container py-4 d-flex justify-content-between align-items-center flex-wrap gap-2"><div><strong>Cozy Coffee Shop</strong><div class="small">Handcrafted drinks • Friendly smiles • Every day</div></div><span class="small">&copy; 2026 Cozy Coffee Shop. Brewed with love.</span></div></footer>
}
    <script src="~/lib/jquery/dist/jquery.min.js"></script><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
