<!DOCTYPE html>
<html lang="vi" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coffe-latteKawaii</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;600;700&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-surface": "#1a1c19",
                        "surface-container-highest": "#e3e3de",
                        "on-error-container": "#93000a",
                        "on-secondary-container": "#676351",
                        "primary-fixed": "#ffdad4",
                        "on-error": "#ffffff",
                        "surface-dim": "#dadad5",
                        "outline": "#827472",
                        "tertiary": "#241500",
                        "secondary-fixed": "#e9e2cc",
                        "on-surface-variant": "#504442",
                        "surface-container-low": "#f4f4ef",
                        "error-container": "#ffdad6",
                        "surface": "#fafaf5",
                        "background": "#fafaf5",
                        "tertiary-container": "#3c290c",
                        "secondary-container": "#e6e0c9",
                        "surface-tint": "#745853",
                        "primary-container": "#3e2723",
                        "surface-container-lowest": "#ffffff",
                        "on-background": "#1a1c19",
                        "outline-variant": "#d3c3c0",
                        "error": "#ba1a1a",
                        "primary": "#271310",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#e3beb8",
                        "surface-container": "#eeeee9",
                        "surface-bright": "#fafaf5",
                        "on-primary-container": "#ae8d87",
                        "on-secondary": "#ffffff",
                        "secondary": "#625f4d",
                        "surface-container-high": "#e8e8e3",
                        "surface-variant": "#e3e3de"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    },
                    spacing: {
                        "margin-mobile": "16px",
                        "unit": "8px",
                        "gutter": "24px",
                        "section-gap": "80px",
                        "container-max": "1200px",
                        "margin-desktop": "40px"
                    },
                    fontFamily: {
                        "display": ["Noto Serif", "serif"],
                        "display-lg": ["Noto Serif", "serif"],
                        "headline-lg": ["Noto Serif", "serif"],
                        "headline-md": ["Noto Serif", "serif"],
                        "body": ["Be Vietnam Pro", "sans-serif"],
                        "body-md": ["Be Vietnam Pro", "sans-serif"],
                        "body-lg": ["Be Vietnam Pro", "sans-serif"],
                        "caption": ["Be Vietnam Pro", "sans-serif"],
                        "label-md": ["Be Vietnam Pro", "sans-serif"]
                    },
                    fontSize: {
                        "display-lg": ["48px", { lineHeight: "56px", letterSpacing: "-0.02em", fontWeight: "700" }],
                        "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
                        "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
                        "caption": ["12px", { lineHeight: "16px", fontWeight: "400" }],
                        "headline-lg": ["32px", { lineHeight: "40px", fontWeight: "600" }],
                        "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.05em", fontWeight: "600" }],
                        "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background font-body text-on-background selection:bg-primary-fixed">
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
