<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coffee Latte Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell d-flex flex-column">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold brand-float" asp-controller="Product" asp-action="Index">☕ Coffee Latte Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="UploadImageList">Upload ảnh</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Add">Thêm sản phẩm</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main container flex-grow-1">
        @RenderBody()
    </main>

    <footer class="app-footer text-light mt-auto">
        <div class="container py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 Coffee Latte Shop</span>
            <span>Fresh beans • Warm moments</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
